# ─────────────────────────────────────────────────────────────────────────────
# .env.example — RDTI AI Agent
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Replace every value marked <...> with your real credentials.
#   3. Never commit .env to version control — add it to .gitignore.
#
# This file IS safe to commit. It contains no real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Your OpenAI API key.
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=<your-openai-api-key>

# ── Australian Business Register (ABR) ───────────────────────────────────────
# Authentication GUID issued by the ATO for the ABR XML Search API.
# Register at: https://abr.business.gov.au/Tools/WebServices
ABR_AUTH_GUID=<your-abr-authentication-guid>

# ── Django backend ───────────────────────────────────────────────────────────
# Full URL to the Django REST API submissions endpoint.
# Example production value: https://yourdomain.com/api/rdti/submissions/
DJANGO_API_URL=http://localhost:8000/api/rdti/submissions/

# Bearer token for authenticating with the Django REST API.
# Generate with: python manage.py drf_create_token <username>
DJANGO_API_TOKEN=<your-django-api-token>
